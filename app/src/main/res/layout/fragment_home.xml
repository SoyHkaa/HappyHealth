<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:paddingHorizontal="16dp"
    android:paddingVertical="32dp"
    tools:context=".HomeFragment">

    <!-- Tarjeta 1: Visita Clínica -->
    <androidx.cardview.widget.CardView
        android:id="@+id/visitClinic"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:layout_marginEnd="8dp"
        app:cardBackgroundColor="@color/blue"
        app:cardCornerRadius="5dp"
        app:layout_constraintEnd_toStartOf="@+id/homeVisit"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_margin="12dp"
            android:gravity="left"
            android:orientation="vertical">
            <ImageView
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:src="@drawable/ic_doctor" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="Visita clínica"
                android:textColor="@color/white"
                android:textSize="17sp"
                android:textStyle="bold" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Agenda una cita"
                android:textColor="@color/white" />
        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <!-- Tarjeta 2: Visita en el hogar -->
    <androidx.cardview.widget.CardView
        android:id="@+id/homeVisit"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="8dp"
        app:cardBackgroundColor="@color/white"
        app:cardCornerRadius="5dp"
        app:layout_constraintBottom_toBottomOf="@+id/visitClinic"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toEndOf="@id/visitClinic"
        app:layout_constraintTop_toTopOf="@+id/visitClinic">
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_margin="12dp"
            android:gravity="left"
            android:orientation="vertical">
            <ImageView
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:src="@drawable/ic_home" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="Visita en casa"
                android:textColor="@color/blue"
                android:textSize="17sp"
                android:textStyle="bold" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Agenda una cita"
                android:textColor="@color/black" />
        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <!-- Selección de los sintomas síntomas -->
    <TextView
        android:id="@+id/txtSymptoms"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:text="1. ¿Cuáles son tus síntomas?"
        android:textSize="16sp"
        android:textStyle="bold"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/visitClinic" />

    <com.google.android.material.chip.ChipGroup
        android:id="@+id/chipGroupSintomas"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        app:layout_constraintTop_toBottomOf="@id/txtSymptoms"
        app:singleSelection="false">

        <com.google.android.material.chip.Chip
            android:id="@+id/chipFiebre" style="@style/Widget.MaterialComponents.Chip.Filter" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Fiebre" />
        <com.google.android.material.chip.Chip
            android:id="@+id/chipTos" style="@style/Widget.MaterialComponents.Chip.Filter" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Tos" />
        <com.google.android.material.chip.Chip
            android:id="@+id/chipCabeza" style="@style/Widget.MaterialComponents.Chip.Filter" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Dolor de cabeza" />
        <com.google.android.material.chip.Chip
            android:id="@+id/chipNauseas" style="@style/Widget.MaterialComponents.Chip.Filter" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Náuseas" />
        <com.google.android.material.chip.Chip
            android:id="@+id/chipFatiga" style="@style/Widget.MaterialComponents.Chip.Filter" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Fatiga" />
        <com.google.android.material.chip.Chip
            android:id="@+id/chipMuscular" style="@style/Widget.MaterialComponents.Chip.Filter" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Dolor Muscular" />
        <com.google.android.material.chip.Chip
            android:id="@+id/chipMareo" style="@style/Widget.MaterialComponents.Chip.Filter" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Mareos" />
        <com.google.android.material.chip.Chip
            android:id="@+id/chipOtro" style="@style/Widget.MaterialComponents.Chip.Filter" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Otro" />
    </com.google.android.material.chip.ChipGroup>

    <!-- Campo de Síntoma Personalizado -->
    <EditText
        android:id="@+id/etSintomaPersonalizado"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:hint="Escribe tus síntomas aquí..."
        android:visibility="gone"
        app:layout_constraintTop_toBottomOf="@id/chipGroupSintomas" />

    <!-- Slide de Doctores -->
    <TextView
        android:id="@+id/txtDoctors"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="2. Selecciona tu Doctor:"
        android:textSize="16sp"
        android:textStyle="bold"
        app:layout_constraintTop_toBottomOf="@id/etSintomaPersonalizado"
        app:layout_constraintStart_toStartOf="parent"/>

    <HorizontalScrollView
        android:id="@+id/scrollDoctores"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:scrollbars="none"
        app:layout_constraintTop_toBottomOf="@+id/txtDoctors">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:paddingBottom="8dp"
            android:orientation="horizontal">

            <androidx.cardview.widget.CardView
                android:id="@+id/docChris" android:layout_width="140dp" android:layout_height="wrap_content" android:layout_marginEnd="12dp" app:cardCornerRadius="8dp" app:cardBackgroundColor="@color/white">
                <LinearLayout android:layout_width="match_parent" android:layout_height="match_parent" android:layout_margin="12dp" android:orientation="vertical" android:gravity="center">
                    <ImageView android:layout_width="50dp" android:layout_height="50dp" android:src="@drawable/ic_doctor" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="8dp" android:text="Dr. Chris Frazie" android:textColor="@color/black" android:textStyle="bold" android:gravity="center"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Pediatra" android:textSize="12sp" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <androidx.cardview.widget.CardView
                android:id="@+id/docViola" android:layout_width="140dp" android:layout_height="wrap_content" android:layout_marginEnd="12dp" app:cardCornerRadius="8dp" app:cardBackgroundColor="@color/white">
                <LinearLayout android:layout_width="match_parent" android:layout_height="match_parent" android:layout_margin="12dp" android:orientation="vertical" android:gravity="center">
                    <ImageView android:layout_width="50dp" android:layout_height="50dp" android:src="@drawable/ic_doctor" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="8dp" android:text="Dr. Viola Dunn" android:textColor="@color/black" android:textStyle="bold" android:gravity="center"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Pediatra" android:textSize="12sp" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <androidx.cardview.widget.CardView
                android:id="@+id/docKatherine" android:layout_width="140dp" android:layout_height="wrap_content" android:layout_marginEnd="12dp" app:cardCornerRadius="8dp" app:cardBackgroundColor="@color/white">
                <LinearLayout android:layout_width="match_parent" android:layout_height="match_parent" android:layout_margin="12dp" android:orientation="vertical" android:gravity="center">
                    <ImageView android:layout_width="50dp" android:layout_height="50dp" android:src="@drawable/ic_doctor" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="8dp" android:text="Katherine Rojas" android:textColor="@color/black" android:textStyle="bold" android:gravity="center"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="General" android:textSize="12sp" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <androidx.cardview.widget.CardView
                android:id="@+id/docKevin" android:layout_width="140dp" android:layout_height="wrap_content" android:layout_marginEnd="12dp" app:cardCornerRadius="8dp" app:cardBackgroundColor="@color/white">
                <LinearLayout android:layout_width="match_parent" android:layout_height="match_parent" android:layout_margin="12dp" android:orientation="vertical" android:gravity="center">
                    <ImageView android:layout_width="50dp" android:layout_height="50dp" android:src="@drawable/ic_doctor" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="8dp" android:text="Kevin Benalcazar" android:textColor="@color/black" android:textStyle="bold" android:gravity="center"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Cardiología" android:textSize="12sp" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <androidx.cardview.widget.CardView
                android:id="@+id/docManuela" android:layout_width="140dp" android:layout_height="wrap_content" android:layout_marginEnd="12dp" app:cardCornerRadius="8dp" app:cardBackgroundColor="@color/white">
                <LinearLayout android:layout_width="match_parent" android:layout_height="match_parent" android:layout_margin="12dp" android:orientation="vertical" android:gravity="center">
                    <ImageView android:layout_width="50dp" android:layout_height="50dp" android:src="@drawable/ic_doctor" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="8dp" android:text="Manuela Beltrán" android:textColor="@color/black" android:textStyle="bold" android:gravity="center"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="General" android:textSize="12sp" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <androidx.cardview.widget.CardView
                android:id="@+id/docSofia" android:layout_width="140dp" android:layout_height="wrap_content" android:layout_marginEnd="12dp" app:cardCornerRadius="8dp" app:cardBackgroundColor="@color/white">
                <LinearLayout android:layout_width="match_parent" android:layout_height="match_parent" android:layout_margin="12dp" android:orientation="vertical" android:gravity="center">
                    <ImageView android:layout_width="50dp" android:layout_height="50dp" android:src="@drawable/ic_doctor" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="8dp" android:text="Sofía López" android:textColor="@color/black" android:textStyle="bold" android:gravity="center"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Especialista" android:textSize="12sp" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <androidx.cardview.widget.CardView
                android:id="@+id/docArturo" android:layout_width="140dp" android:layout_height="wrap_content" android:layout_marginEnd="12dp" app:cardCornerRadius="8dp" app:cardBackgroundColor="@color/white">
                <LinearLayout android:layout_width="match_parent" android:layout_height="match_parent" android:layout_margin="12dp" android:orientation="vertical" android:gravity="center">
                    <ImageView android:layout_width="50dp" android:layout_height="50dp" android:src="@drawable/ic_doctor" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="8dp" android:text="Arturo Vidal" android:textColor="@color/black" android:textStyle="bold" android:gravity="center"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Cardiología" android:textSize="12sp" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>
        </LinearLayout>
    </HorizontalScrollView>

    <!-- Cuadro de Previsualización -->
    <TextView
        android:id="@+id/tvDiagnostico"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:background="#F5F5F5"
        android:padding="16dp"
        android:text="Selecciona síntomas y un doctor."
        android:textColor="@color/black"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/scrollDoctores" />

    <!-- Botón de Reserva -->
    <Button
        android:id="@+id/btnReservarCita"
        android:layout_width="0dp"
        android:layout_height="55dp"
        android:layout_marginTop="16dp"
        android:backgroundTint="@color/blue"
        android:text="Ir a Reservar Cita"
        android:textColor="@color/white"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tvDiagnostico" />

    
</androidx.constraintlayout.widget.ConstraintLayout>